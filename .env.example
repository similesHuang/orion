# Orion configuration
# Copy this file to `.env` and fill in your own values.
# Do not commit `.env` — it contains secrets.

# UI language: zh or en
GA_LANG=zh

# LLM configuration
# TYPE: claude | oai | mixin
# Use `claude` for Anthropic-native endpoints (including Kimi coding endpoint).
# Use `oai` for OpenAI-compatible endpoints.
LLM_TYPE=claude
LLM_NAME=kimi-k2.7
LLM_APIKEY=sk-your-api-key
LLM_APIBASE=https://api.kimi.com/coding/
LLM_MODEL=kimi-k2.7
LLM_MAX_RETRIES=3
LLM_CONNECT_TIMEOUT=10
LLM_READ_TIMEOUT=120

# Optional fields
# LLM_CONTEXT_WIN=28000
# LLM_PROXY=
# LLM_VERIFY=true
# LLM_STREAM=true
# LLM_TIMEOUT=10
# LLM_TEMPERATURE=1
# LLM_MAX_TOKENS=8192
# LLM_API_MODE=chat_completions
# LLM_REASONING_EFFORT=medium
# LLM_THINKING_TYPE=adaptive
# LLM_THINKING_BUDGET_TOKENS=4096
# LLM_FAKE_CC_SYSTEM_PROMPT=false
# LLM_USER_AGENT=

# Multiple LLMs (optional)
# LLM_0_TYPE=oai
# LLM_0_NAME=gpt-native
# LLM_0_APIKEY=sk-your-openai-key
# LLM_0_APIBASE=https://api.openai.com/v1
# LLM_0_MODEL=gpt-5.4

# Langfuse tracing (optional)
# LANGFUSE_CONFIG={"publicKey":"...","secretKey":"...","baseUrl":"..."}

# ModelScope vision API fallback (optional)
# MODELSCOPE_API_KEY=sk-your-modelscope-key
