{
  "name": "orion",
  "version": "0.1.0",
  "private": true,
  "description": "Orion TypeScript workspace",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @orion/cli dev",
    "cli": "pnpm --filter @orion/cli cli",
    "desktop:dev": "pnpm --filter @orion/desktop dev:clean",
    "desktop:build": "pnpm --filter @orion/desktop build",
    "gateway": "pnpm --filter @orion/gateway start",
    "lint": "eslint packages apps",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "clean": "pnpm -r exec rm -rf dist",
    "ultraplan:daemon": "tsx packages/agent/src/ultraplan-daemon.ts --daemon"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1"
  }
}
