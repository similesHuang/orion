{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Orion",
  "version": "0.1.0",
  "identifier": "com.orion.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --dir ./ui dev"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Orion",
        "width": 1100,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "dist/sidecar": "dist/sidecar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
